{
  "compilerOptions": {
    "jsx": "react-native",
    "lib": ["es2020"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "target": "es2020",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
  },
  "include": [
    "App.tsx",
    "client/src/**/*"
  ],
  "exclude": [
    "node_modules"
  ],
  "extends": "expo/tsconfig.base"
}
