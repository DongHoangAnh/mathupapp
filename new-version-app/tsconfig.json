{
  "compilerOptions": {
    "jsx": "react-native",
    "lib": ["es2020"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "target": "es2020",
    "skipLibCheck": true,
  },
  "include": [
    "App.tsx",
    "client/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "client/src/components/game-results.tsx",
    "client/src/components/protected-route.tsx"
  ],
  "extends": "expo/tsconfig.base"
}
